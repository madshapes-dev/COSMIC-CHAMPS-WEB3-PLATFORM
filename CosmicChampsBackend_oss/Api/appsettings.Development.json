{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Grpc": "Information"
    }
  },
  "DynamoDB": {
    "Region": "eu-central-1",
    "TablePrefix": "Dev-"
  },
  "AppConfig": {
    "ApplicationId": "<app_id>",
    "EnvironmentId": "<env_id>",
    "ProfileId": "<profile_id>"
  },
  "GameLift": {
    "Region": "eu-central-1",
    "MatchmakingConfiguration": "CosmicChamps-Dev",
    "TournamentMatchmakingConfiguration": "CosmicChamps-Tournament-Dev",
    "PrizeBotMatchmakingConfiguration": "CosmicChamps-PrizeBot-Dev",
    "TutorBotMatchmakingConfiguration": "CosmicChamps-TutorBot-Dev"
  },
  "LocalMatchmaking": {
    "PVPTimeout": 30
  }
}