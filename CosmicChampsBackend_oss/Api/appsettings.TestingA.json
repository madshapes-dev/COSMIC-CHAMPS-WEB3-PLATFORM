    "TournamentMatchmakingConfiguration": "CosmicChamps-Tournament-TestA",
    "PrizeBotMatchmakingConfiguration": "CosmicChamps-PrizeBot-TestA",
    "TutorBotMatchmakingConfiguration": "CosmicChamps-TutorBot-TestA"
  }  
}